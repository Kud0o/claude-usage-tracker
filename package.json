{
  "name": "claude-usage-tracker",
  "version": "1.0.0",
  "description": "Zero-dependency Claude Code hook that records every prompt (tokens, model, mode, effort, context %, cost) and shows it in a local dashboard.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "claude-usage-tracker": "install.mjs"
  },
  "scripts": {
    "install-hook": "node install.mjs",
    "install-local": "node install.mjs --local",
    "uninstall": "node install.mjs --uninstall",
    "view": "node viewer/server.mjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "hook",
    "usage",
    "tokens",
    "cost",
    "dashboard",
    "observability"
  ],
  "dependencies": {}
}
